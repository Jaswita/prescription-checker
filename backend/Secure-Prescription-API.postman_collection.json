{
  "info": {
    "name": "Secure Prescription System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing Secure Prescription Verification & Controlled Substance Tracking System"
  },
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/auth/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "auth", "register"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Doctor User\",\n  \"email\": \"doctor@test.com\",\n  \"password\": \"Doctor@123\",\n  \"role\": \"doctor\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"doctor@test.com\",\n  \"password\": \"Doctor@123\"\n}"
        }
      }
    },
    {
      "name": "Auth - Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/auth/verify-otp",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "auth", "verify-otp"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"doctor@test.com\",\n  \"otp\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "Prescription - Create (Doctor)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{JWT_TOKEN}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/prescriptions/create",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "prescriptions", "create"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": \"PATIENT_USER_ID\",\n  \"drugName\": \"Paracetamol\",\n  \"dosage\": \"500mg twice daily\",\n  \"isControlledSubstance\": false\n}"
        }
      }
    },
    {
      "name": "Prescription - Verify (Public/Pharmacy)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/prescriptions/verify",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "prescriptions", "verify"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prescriptionId\": \"PRESCRIPTION_ID_HERE\"\n}"
        }
      }
    },
    {
      "name": "Prescription - Dispense (Pharmacy)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{JWT_TOKEN}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/prescriptions/dispense",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "prescriptions", "dispense"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prescriptionId\": \"PRESCRIPTION_ID_HERE\"\n}"
        }
      }
    },
    {
      "name": "Admin - Get Users",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{JWT_TOKEN}}" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/admin/users",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "admin", "users"]
        }
      }
    },
    {
      "name": "Admin - Get Logs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{JWT_TOKEN}}" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/admin/logs",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "admin", "logs"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "JWT_TOKEN",
      "value": ""
    }
  ]
}